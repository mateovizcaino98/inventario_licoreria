        <attribute name="edited" value="SFA7TEFQVE9QLURBTVJJQUhQOzIwMjYtMDYtMjY7MDg6MDk6MTYgcC7CoG0uOzE7Mjk1OQ=="/>
        <attribute name="edited" value="VXN1YXJpbztERVNLVE9QLVFSRE5KNTI7MjAyNi0wNi0yNjswODozMjozOCBwLsKgbS47MTttYXRlbztERVNLVE9QLU02MU1ORjg7MjAyNi0wNi0yNDswOToxMToxNCBwLiBtLjtpbnZlbnRhcmlvX2xpY29yZXJpYS5mcHJnOzkzMDg="/>
        <attribute name="edited" value="VXN1YXJpbztERVNLVE9QLVFSRE5KNTI7MjAyNi0wNi0yNjswODozNDo0MSBwLsKgbS47MTszNTI1"/>
        <attribute name="edited" value="TGFwdG9wLVBDO01BVEVPR1BDOzIwMjYtMDYtMjY7MDk6NDU6NTIgcC7CoG0uOzI7MzEyNg=="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="sistemaencendido" type="Boolean" array="False" size=""/>
            <assign variable="sistemaencendido" expression="true"/>
            <while expression="sistemaencendido = true">
                <declare name="selecci&#243;n, selecci&#243;nlistaproductos, selecci&#243;nactualizar" type="Integer" array="False" size=""/>
                <output expression="&quot;====Men&#250;====&quot;" newline="True"/>
                <output expression="&quot;1. Mostrar lista de productos&quot;" newline="True"/>
                <output expression="&quot;2. A&#241;adir un producto&quot;" newline="True"/>
                <output expression="&quot;3. Actualizar un producto&quot;" newline="True"/>
                <output expression="&quot;4. Salir&quot;" newline="True"/>
                <input variable="selecci&#243;n"/>
                <if expression="selecci&#243;n = 1">
                    <then>
                        <output expression="&quot;==Mostrar lista de productos==&quot;" newline="True"/>
                        <output expression="&quot;1. Ver todos los productos&quot;" newline="True"/>
                        <output expression="&quot;2. Buscar producto espec&#237;fico&quot;" newline="True"/>
                        <input variable="selecci&#243;nlistaproductos"/>
                        <if expression="selecci&#243;nlistaproductos = 1">
                            <then>
                                <output expression="&quot;Whisky Johnnie Walker Red Label - $25&quot;" newline="True"/>
                                <output expression="&quot;Whisky Chivas Regal 12 A&#241;os - $40&quot;" newline="True"/>
                                <output expression="&quot;Ron Abuelo 7 A&#241;os - $22&quot;" newline="True"/>
                                <output expression="&quot;Ron Zacapa 23 - $55&quot;" newline="True"/>
                                <output expression="&quot;Vodka Absolut - $20&quot;" newline="True"/>
                                <output expression="&quot;Vodka Smirnoff - $15&quot;" newline="True"/>
                                <output expression="&quot;Tequila Jos&#233; Cuervo Especial - $28&quot;" newline="True"/>
                                <output expression="&quot;Tequila Don Julio Blanco - $60&quot;" newline="True"/>
                                <output expression="&quot;Cerveza Corona (6 pack) - $8&quot;" newline="True"/>
                                <output expression="&quot;Cerveza Pilsener (6 pack) - $6&quot;" newline="True"/>
                                <output expression="&quot;Vino Casillero del Diablo - $12&quot;" newline="True"/>
                                <output expression="&quot;Vino Trapiche Malbec - $14&quot;" newline="True"/>
                            </then>
                            <else/>
                        </if>
                        <if expression="selecci&#243;nlistaproductos = 2">
                            <then>
                                <output expression="&quot;Aqu&#237; va el c&#243;digo para buscar un producto en espec&#237;fico&quot;" newline="True"/>
                            </then>
                            <else/>
                        </if>
                        <if expression="selecci&#243;nlistaproductos &lt;&gt; 1 AND selecci&#243;nlistaproductos &lt;&gt; 2">
                            <then>
                                <output expression="&quot;Opci&#243;n inv&#225;lida&quot;" newline="True"/>
                            </then>
                            <else/>
                        </if>
                    </then>
                    <else/>
                </if>
                <if expression="selecci&#243;n = 2">
                    <then>
                        <output expression="&quot;==A&#241;adir un producto==&quot;" newline="True"/>
                        <declare name="ProductoNuevo" type="String" array="False" size=""/>
                        <declare name="CodigoProductoNuevo" type="Real" array="False" size=""/>
                        <output expression="&quot;Coloque el nombre del nuevo producto.&quot;" newline="True"/>
                        <input variable="ProductoNuevo"/>
                        <output expression="&quot;Coloca el codigo del producto.&quot;" newline="True"/>
                        <input variable="CodigoProductoNuevo"/>
                        <output expression="&quot;Se a&#241;adio al inventario: &quot; &amp; ProductoNuevo &amp; &quot; con el c&#243;digo:&quot; &amp; CodigoProductoNuevo" newline="True"/>
                    </then>
                    <else/>
                </if>
                <if expression="selecci&#243;n = 3">
                    <then>
                        <output expression="&quot;===Actualizar un producto===&quot;" newline="True"/>
                        <output expression="&quot;1. Venta&quot;" newline="True"/>
                        <output expression="&quot;2. Actualizar todos los campos&quot;" newline="True"/>
                        <input variable="selecci&#243;nactualizar"/>
                        <if expression="selecci&#243;nactualizar = 1">
                            <then>
                                <declare name="codigodelproducto" type="Integer" array="False" size=""/>
                                <declare name="cantidadvendida" type="Integer" array="False" size=""/>
                                <output expression="&quot;ingrese el codigo del producto&quot;" newline="True"/>
                                <input variable="codigodelproducto"/>
                                <output expression="&quot;ingrese la cantidad vendida&quot;" newline="True"/>
                                <input variable="cantidadvendida"/>
                                <comment text="Aqui sucede la operacion"/>
                                <output expression="&quot;cantidad actualizada exitosamente&quot;" newline="True"/>
                            </then>
                            <else/>
                        </if>
                        <if expression="selecci&#243;nactualizar = 2">
                            <then>
                                <declare name="nombredelproducto" type="String" array="False" size=""/>
                                <output expression="&quot;Ingrese el nombre del producto&quot;" newline="True"/>
                                <input variable="nombredelproducto"/>
                                <declare name="preciodeventadelproducto" type="Real" array="False" size=""/>
                                <output expression="&quot;Ingrese el precio de venta del producto&quot;" newline="True"/>
                                <input variable="preciodeventadelproducto"/>
                                <declare name="preciodecompradelproducto" type="Real" array="False" size=""/>
                                <output expression="&quot;Ingrese el precio de compra del producto&quot;" newline="True"/>
                                <input variable="preciodecompradelproducto"/>
                            </then>
                            <else/>
                        </if>
                        <if expression="selecci&#243;nactualizar &lt;&gt; 1 AND selecci&#243;nactualizar &lt;&gt; 2">
                            <then>
                                <output expression="&quot;Opci&#243;n inv&#225;lida&quot;" newline="True"/>
                            </then>
                            <else/>
                        </if>
                    </then>
                    <else/>
                </if>
                <if expression="selecci&#243;n = 4">
                    <then>
                        <assign variable="sistemaencendido" expression="false"/>
                        <output expression="&quot;El programa ha finalizado&quot;" newline="True"/>
                    </then>
                    <else/>
                </if>
                <if expression="selecci&#243;n &lt;&gt; 1 AND selecci&#243;n &lt;&gt; 2 AND selecci&#243;n &lt;&gt; 3 AND selecci&#243;n &lt;&gt; 4">
                    <then>
                        <output expression="&quot;Opci&#243;n inv&#225;lida&quot;" newline="True"/>
                    </then>
                    <else/>
                </if>
            </while>
        </body>
    </function>
</flowgorithm>
